# Exclude data folder - data is generated before deployment
data/

# Exclude high-res images - only converted WebP images in assets/api are needed
images-hd/

# Exclude database folder - local development only
database/

# Note: scripts/ folder is included because vercel-build.js is needed during build
# The other scripts won't cause issues if included

# Exclude documentation
docs/

# Exclude development files
*.md
!README.md

# Exclude test files if any
**/__tests__/
**/*.test.js
**/*.spec.js

# Exclude IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Exclude OS files
.DS_Store
Thumbs.db

