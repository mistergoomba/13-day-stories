{
  "name": "13-day-stories",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "private": true,
  "scripts": {
    "start": "npx expo start -c",
    "start:lan": "npx expo start -c --lan",
    "start:tunnel": "npx expo start -c --tunnel",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "stop": "pkill -f 'expo start' || true",
    "clean": "rm -rf node_modules/.cache .expo && npm start",
    "build:android": "eas build --platform android --profile preview",
    "build:android:dev": "eas build --platform android --profile development",
    "generate": "npm run generate:birthdays && npm run generate:data",
    "generate:birthdays": "node scripts/insert-birthdays.js",
    "generate:data": "node scripts/generate-data.js",
    "upload:cdn": "node scripts/upload-to-r2.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/stack": "^7.4.10",
    "expo": "~54.0.27",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "^19.0.21",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.15",
    "expo-sharing": "^14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-google-mobile-ads": "^16.0.1",
    "react-native-iap": "^14.5.0",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.16.0",
    "react-native-share": "^12.2.1",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "babel-preset-expo": "^54.0.4",
    "pg": "^8.11.3",
    "sharp": "^0.34.5"
  }
}
